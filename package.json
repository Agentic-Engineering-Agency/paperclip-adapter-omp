{
  "name": "@agentic-engineering-agency/paperclip-adapter-omp",
  "version": "0.5.0",
  "description": "Paperclip adapter for running Oh My Pi (omp) as a local agent runtime.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    },
    "./ui-parser": {
      "types": "./dist/ui-parser.d.ts",
      "import": "./dist/ui-parser.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@paperclipai/adapter-utils": "2026.703.0-canary.5",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "homepage": "https://github.com/Agentic-Engineering-Agency/paperclip-adapter-omp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Agentic-Engineering-Agency/paperclip-adapter-omp.git"
  },
  "bugs": {
    "url": "https://github.com/Agentic-Engineering-Agency/paperclip-adapter-omp/issues"
  },
  "keywords": [
    "paperclip",
    "paperclipai",
    "adapter",
    "omp",
    "oh-my-pi",
    "ai-agent",
    "coding-agent"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "paperclip": {
    "adapterUiParser": "1.0.0"
  }
}
