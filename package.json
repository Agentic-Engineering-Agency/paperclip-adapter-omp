{
  "name": "@agentic-engineering-agency/paperclip-adapter-omp",
  "version": "0.1.0",
  "description": "Paperclip adapter for running Oh My Pi (omp) locally.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    },
    "./cli": {
      "types": "./dist/cli/index.d.ts",
      "import": "./dist/cli/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@paperclipai/adapter-utils": "2026.703.0-canary.5",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts"
}
